{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "S3Access",
			"Effect": "Allow",
			"Action": [
				"s3:GetObject",
				"s3:PutObject",
				"s3:ListBucket"
			],
			"Resource": [
				"arn:aws:s3:::yt-project-bronze",
				"arn:aws:s3:::yt-project-bronze/*",
				"arn:aws:s3:::yt-project-silver",
				"arn:aws:s3:::yt-project-silver/*",
				"arn:aws:s3:::yt-data-pipeline-glue-athena-q-result",
				"arn:aws:s3:::yt-data-pipeline-glue-athena-q-result/*"
			]
		},
		{
			"Sid": "GlueAccess",
			"Effect": "Allow",
			"Action": [
				"glue:GetTable",
				"glue:GetDatabase",
				"glue:CreateTable",
				"glue:UpdateTable",
				"glue:GetPartitions",
				"glue:CreatePartition",
				"glue:BatchCreatePartition"
			],
			"Resource": "*"
		},
		{
			"Sid": "SNSAccess",
			"Effect": "Allow",
			"Action": "sns:Publish",
			"Resource": "arn:aws:sns:eu-north-1:296886268943:yt-data-pipeline-alerts-dev"
		},
		{
			"Sid": "AthenaAccess",
			"Effect": "Allow",
			"Action": [
				"athena:StartQueryExecution",
				"athena:GetQueryExecution",
				"athena:GetQueryResults",
				"athena:GetWorkGroup"
			],
			"Resource": [
				"arn:aws:athena:eu-north-1:296886268943:workgroup/primary",
				"arn:aws:athena:eu-north-1:296886268943:datacatalog/*"
			]
		}
	]
}